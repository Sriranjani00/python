if __name__ == '__main__':
    students = []
    for _ in range(int(input())):
        name = input()
        score = float(input())
        students.append([name, score])

    # 1. Get all unique scores and sort them
    # Set removes duplicates, sorted() puts them in ascending order
    unique_scores = sorted(set(score for name, score in students))
    
    # 2. Identify the second lowest score
    second_lowest_score = unique_scores[1]
    
    # 3. Collect names of students with the second lowest score
    # Use a list comprehension to filter and then sort the names
    result_names = sorted([name for name, score in students if score == second_lowest_score])
    
    # 4. Print each name on a new line
    for name in result_names:
        print(name)
