def merge_the_tools(string, k):
   
    for i in range(0, len(string), k):
        t = string[i : i + k]
        
        # Use a dictionary or a list to track seen characters while maintaining order
        u = ""
        for char in t:
            if char not in u:
                u += char
        print(u)

if __name__ == '__main__':
    string, k = input(), int(input())
    merge_the_tools(string, k)
